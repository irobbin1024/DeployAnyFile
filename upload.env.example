# 复制为 upload.env 后填入（upload.env 已被 .gitignore 忽略，不会提交）

# 上传用的后端 API 地址（不要带结尾斜杠）
DAF_URL=https://your-domain

# 分享链接展示地址；开发模式下后端(8080)与前端(5173)分离时填前端地址。
# 生产单端口部署时与 DAF_URL 相同，可不填。
# DAF_SHARE_URL=http://127.0.0.1:5173

# 【推荐】API 令牌：在网页「API 令牌」页生成，仅能上传，泄露风险低
DAF_TOKEN=daf_xxxxxxxxxxxxxxxx

# 【可选】若不用令牌，可改用账号密码（脚本会自动登录换取临时 token）
# DAF_USER=irobbin
# DAF_PASS=你的密码
