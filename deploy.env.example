# 复制为 deploy.env 后填入你的群晖信息（deploy.env 已被 .gitignore 忽略，不会提交）

# NAS 的 SSH 登录用户（一般是你的管理员账号）
NAS_USER=irobbin

# NAS 的局域网 IP 或域名
NAS_HOST=nas.irobbin.com

# SSH 端口
NAS_PORT=1024

# NAS 上存放本项目源码的目录
NAS_PATH=/volume1/docker/DeployAnyFile_SRC

# Container Manager 里的项目(project)名
NAS_PROJECT=deploy_any_file
