# Copy to .env and adjust. Used by docker-compose / local runs.

# HTTP listen address
BIND_ADDR=0.0.0.0:8080

# Where the SQLite DB and uploaded files live (a Docker volume in production)
DATA_DIR=./data

# Secret used to sign login tokens — MUST be changed to a long random string
JWT_SECRET=please-change-this-to-a-long-random-string

# Super admin bootstrap account (created on first start if missing)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Max upload size in megabytes
MAX_UPLOAD_MB=100

# Directory of the built frontend (set automatically inside Docker)
# STATIC_DIR=./static
